generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String

  worlds    World[]
  commander Commander?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model World {
  id                String   @id @default(uuid())

  name              String

  planetType        String
  temperature       Int
  waterLevel        Int
  oxygenLevel       Int

  currentYear       Int      @default(0)
  currentEra        String   @default("Primitive")

  disasterFrequency Int      @default(10)
  season            String   @default("Season 1: Rise of Civilizations")

  userId            String
  user              User     @relation(fields: [userId], references: [id])

  species           Species[]

  history           EvolutionHistory[]

  disasters DisasterEvent[]
  starSystems StarSystem[]
  decisions   PlayerDecision[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Species {
  id            String   @id @default(uuid())

  name          String
  population    Int      @default(100)

  worldId       String
  world         World    @relation(fields: [worldId], references: [id])

  dna           DNA?

  mutations     MutationEvent[]

  civilization  Civilization?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DNA {
  id            String   @id @default(uuid())

  strength      Int
  intelligence  Int
  speed         Int
  adaptability  Int
  aggression    Int
  lifespan      Int

  speciesId     String   @unique
  species       Species  @relation(fields: [speciesId], references: [id])

  createdAt     DateTime @default(now())
}

model MutationEvent {
  id          String   @id @default(uuid())

  trait       String

  oldValue    Int
  newValue    Int
  change      Int

  speciesId   String
  species     Species @relation(fields: [speciesId], references: [id])

  createdAt   DateTime @default(now())
}

model EvolutionHistory {
  id          String   @id @default(uuid())

  year        Int

  eventType String @default("GENERAL")

  description String

  worldId     String
  world       World @relation(fields: [worldId], references: [id])

  createdAt   DateTime @default(now())
}

model Civilization {
  id String @id @default(uuid())

  stage String

  populationAtFormation Int

  speciesId String @unique
  species Species @relation(fields: [speciesId], references: [id])

  technology Technology?
  resource Resource?

  militaryPower      Int      @default(100)
  fleetStrength      Int      @default(10)
  technologiesJson   String   @default("[]")
  planets            Planet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DisasterEvent {
  id          String   @id @default(uuid())

  type        String

  severity    Int

  description String

  worldId      String
  world        World @relation(fields: [worldId], references: [id])

  createdAt   DateTime @default(now())
}

model Technology {
  id String @id @default(uuid())

  level Int @default(1)

  era String @default("Stone Age")

  civilizationId String @unique

  civilization Civilization @relation(fields: [civilizationId],references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id String @id @default(uuid())

  food Int @default(100)
  wood Int @default(100)
  stone Int @default(100)
  metal Int @default(100)
  energy Int @default(100)

  civilizationId String @unique

  civilization Civilization @relation(fields: [civilizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model War {
  id String @id @default(uuid())

  attackerId String
  defenderId String

  winner String

  year Int
  status String @default("Active")
  conquestPlanetId String?

  createdAt DateTime @default(now())
}

model Diplomacy {
  id String @id @default(uuid())

  civilizationAId String
  civilizationBId String

  relationship String @default("Neutral")
  treatyType   String @default("None")
  embassy      Boolean @default(false)
  rivalry      Boolean @default(false)
  sanctions    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alliance {
  id String @id @default(uuid())

  civilizationAId String
  civilizationBId String

  createdAt DateTime @default(now())
}

model Trade {
  id String @id @default(uuid())

  sellerId String
  buyerId String

  resource String

  amount Int

  createdAt DateTime @default(now())
}

model Commander {
  id               String   @id @default(uuid())
  name             String
  rank             String   @default("Bronze")
  xp               Int      @default(0)
  reputation       Int      @default(100)
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  achievementsJson String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model StarSystem {
  id       String   @id @default(uuid())
  name     String
  x        Int
  y        Int
  worldId  String
  world    World    @relation(fields: [worldId], references: [id])
  planets  Planet[]
}

model Planet {
  id           String        @id @default(uuid())
  name         String
  type         String
  resources    String
  starSystemId String
  starSystem   StarSystem    @relation(fields: [starSystemId], references: [id])
  ownerId      String?
  owner        Civilization? @relation(fields: [ownerId], references: [id])
}

model PlayerDecision {
  id          String    @id @default(uuid())
  worldId     String
  world       World     @relation(fields: [worldId], references: [id])
  year        Int
  title       String
  description String
  optionsJson String
  choiceMade  Int       @default(-1)
  resolvedAt  DateTime?
}